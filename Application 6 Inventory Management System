/***Inventory Management System 
Build a system to manage store inventory: 
• Add products (ID, Name, Quantity, Price)  
• Update stock  
• Remove product  
• Display inventory  
Features: 
• Alert when stock is low  
• Calculate total inventory value   ***/


import java.util.*;

class Product {
    int id;
    String name;
    int quantity;
    double price;

    public Product(int id, String name, int quantity, double price) {
        this.id = id;
        this.name = name;
        this.quantity = quantity;
        this.price = price;
    }

    public double getValue() {
        return quantity * price;
    }
}

class Inventory {
    HashMap<Integer, Product> products = new HashMap<>();

    public void addProduct(Scanner sc) {
        System.out.print("ID: ");
        int id = sc.nextInt();
        sc.nextLine();

        System.out.print("Name: ");
        String name = sc.nextLine();

        System.out.print("Quantity: ");
        int qty = sc.nextInt();

        System.out.print("Price: ");
        double price = sc.nextDouble();

        products.put(id, new Product(id, name, qty, price));
    }

    public void updateStock(Scanner sc) {
        System.out.print("Enter ID: ");
        int id = sc.nextInt();

        if (products.containsKey(id)) {
            System.out.print("New Quantity: ");
            products.get(id).quantity = sc.nextInt();
        }
    }

    public void removeProduct(Scanner sc) {
        System.out.print("Enter ID: ");
        int id = sc.nextInt();
        products.remove(id);
    }

    public void displayInventory() {
        double total = 0;

        for (Product p : products.values()) {
            System.out.println(p.id + " " + p.name + " " + p.quantity + " " + p.price);

            if (p.quantity < 5) {
                System.out.println("⚠ Low stock alert!");
            }

            total += p.getValue();
        }

        System.out.println("Total Inventory Value: " + total);
    }
}

public class InventorySystem {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Inventory inv = new Inventory();

        while (true) {
            System.out.println("\n1.Add 2.Update 3.Remove 4.Display 5.Exit");
            int ch = sc.nextInt();

            switch (ch) {
                case 1: inv.addProduct(sc); break;
                case 2: inv.updateStock(sc); break;
                case 3: inv.removeProduct(sc); break;
                case 4: inv.displayInventory(); break;
                case 5: return;
            }
        }
    }
}
