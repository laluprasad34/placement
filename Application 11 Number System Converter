import java.util.*;

class Converter {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        while (true) {
            System.out.println("\n1.Decimal->Binary 2.Binary->Decimal 3.Exit");
            int ch = sc.nextInt();

            switch (ch) {
                case 1:
                    int d = sc.nextInt();
                    System.out.println(Integer.toBinaryString(d));
                    break;

                case 2:
                    String b = sc.next();
                    System.out.println(Integer.parseInt(b, 2));
                    break;

                case 3:
                    return;
            }
        }
    }
}
