/*** Hotel Room Booking System 
Develop a booking system where: 
• Rooms can be booked and canceled  
• Show available rooms  
• Store customer details  
Constraints: 
• Avoid double booking  
• Room categories (AC, Non-AC)   ***/
import java.util.*;

class Room {
    String roomNo;
    String category;
    boolean isBooked;
    String customer;

    public Room(String roomNo, String category) {
        this.roomNo = roomNo;
        this.category = category;
        this.isBooked = false;
        this.customer = null;
    }
}

class Hotel {
    ArrayList<Room> rooms = new ArrayList<>();

    public void addRoom(String roomNo, String category) {
        rooms.add(new Room(roomNo, category));
    }

    public void showAvailableRooms() {
        System.out.println("\nAvailable Rooms:");
        for (Room r : rooms) {
            if (!r.isBooked) {
                System.out.println(r.roomNo + " " + r.category);
            }
        }
    }

    public void bookRoom(Scanner sc) {
        System.out.print("Enter Room No: ");
        String roomNo = sc.next();

        for (Room r : rooms) {
            if (r.roomNo.equals(roomNo) && !r.isBooked) {
                sc.nextLine();
                System.out.print("Customer Name: ");
                String name = sc.nextLine();

                r.isBooked = true;
                r.customer = name;
                System.out.println("Room booked successfully!");
                return;
            }
        }

        System.out.println("Room not available!");
    }

    public void cancelBooking(Scanner sc) {
        System.out.print("Enter Room No: ");
        String roomNo = sc.next();

        for (Room r : rooms) {
            if (r.roomNo.equals(roomNo) && r.isBooked) {
                r.isBooked = false;
                r.customer = null;
                System.out.println("Booking cancelled!");
                return;
            }
        }

        System.out.println("Invalid room or not booked!");
    }
}

public class HotelBookingSystem {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Hotel hotel = new Hotel();

        // Predefined rooms
        hotel.addRoom("101", "AC");
        hotel.addRoom("102", "Non-AC");
        hotel.addRoom("103", "AC");

        while (true) {
            System.out.println("\n1.Show 2.Book 3.Cancel 4.Exit");
            int ch = sc.nextInt();

            switch (ch) {
                case 1: hotel.showAvailableRooms(); break;
                case 2: hotel.bookRoom(sc); break;
                case 3: hotel.cancelBooking(sc); break;
                case 4: return;
            }
        }
    }
}
