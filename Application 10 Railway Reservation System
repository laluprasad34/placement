import java.util.*;

class Railway {
    static int seats = 5;
    static Map<Integer, String> bookings = new HashMap<>();
    static int ticketId = 1;

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        while (true) {
            System.out.println("\n1.Book 2.Cancel 3.Availability 4.Exit");
            int ch = sc.nextInt();
            sc.nextLine();

            switch (ch) {
                case 1:
                    if (seats > 0) {
                        System.out.print("Enter name: ");
                        String name = sc.nextLine();
                        bookings.put(ticketId, name);
                        System.out.println("Booked! Ticket ID: " + ticketId);
                        ticketId++;
                        seats--;
                    } else {
                        System.out.println("No seats available");
                    }
                    break;

                case 2:
                    System.out.print("Enter ticket ID: ");
                    int id = sc.nextInt();
                    if (bookings.containsKey(id)) {
                        bookings.remove(id);
                        seats++;
                        System.out.println("Cancelled");
                    }
                    break;

                case 3:
                    System.out.println("Seats left: " + seats);
                    break;

                case 4:
                    return;
            }
        }
    }
}
